---
layout: null
---
[
  {% assign ko_posts = site.posts | where_exp: "item", "item.lang == 'ko' or item.lang == nil" %}
  {% assign why_ko_posts = ko_posts | where_exp: "item", "item.categories contains 'why'" %}
  {% for post in why_ko_posts %}
    {
      "title"    : "{{ post.title | escape }}",
      "url"      : "{{ post.url | relative_url }}",
      "date"     : "{{ post.date | date: '%Y-%m-%d' }}"
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
